# Firebase Config — create a Firebase project at https://console.firebase.google.com
# then enable Email/Password and Google sign-in under Authentication > Sign-in method
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Backend API URL — local dev or deployed backend
VITE_API_BASE_URL=http://localhost:5000/api
